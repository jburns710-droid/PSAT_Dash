function renderCohortContext(s) {
  const fs = filteredStudents();
  const sections = [
    { label: 'Total Score', val: s.total, min: 320, max: 1520, cohortVals: fs.map(x=>x.total) },
    { label: 'Reading & Writing', val: s.rw, min: 160, max: 760, cohortVals: fs.map(x=>x.rw) },
    { label: 'Math', val: s.math, min: 160, max: 760, cohortVals: fs.map(x=>x.math) },
  ];
  return sections.map(sec => {
    const sorted = [...sec.cohortVals].sort((a,b)=>a-b);
    const rank = sorted.filter(v=>v<=sec.val).length;
    const pctile = Math.round(rank/sorted.length*100);
    const avg = Math.round(sec.cohortVals.reduce((a,b)=>a+b,0)/sec.cohortVals.length);
    const valPct = Math.round((sec.val-sec.min)/(sec.max-sec.min)*100);
    const avgPct = Math.round((avg-sec.min)/(sec.max-sec.min)*100);
    return `<div style="margin-bottom:14px">
      <div style="display:flex;justify-content:space-between;margin-bottom:5px">
        <span style="font-size:13px;font-weight:600">${sec.label}</span>
        <span style="font-size:13px;color:var(--text-secondary)">${pctile}th percentile in cohort</span>
      </div>
      <div style="position:relative;height:10px;background:var(--border-subtle);border-radius:5px;margin-bottom:4px">
        <div style="position:absolute;left:0;height:100%;width:${valPct}%;background:${scoreToColor(sec.val)};border-radius:5px;"></div>
        <div style="position:absolute;left:${avgPct}%;top:-5px;width:2px;height:20px;background:var(--text-muted);border-radius:1px;" title="Cohort avg: ${avg}"></div>
      </div>
      <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--text-secondary)">
        <span style="color:${scoreToColor(sec.val)};font-weight:600">${sec.val}</span>
        <span>Cohort avg: ${avg}</span>
      </div>
    </div>`;
  }).join('');
}

// ─── GROUPING ─────────────────────────────────────────────────────────────────
function runGrouping() {
  const domain = document.getElementById('group-domain').value;
  const size = parseInt(document.getElementById('group-size').value);
  const mode = document.getElementById('group-mode').value;
  const fs = filteredStudents();

  const getScore = (s) => {
    const map = { rw:s.rw, math:s.math, total:s.total, ii:bandMid(s.domains.ii), cs:bandMid(s.domains.cs), eoi:bandMid(s.domains.eoi), sec:bandMid(s.domains.sec), alg:bandMid(s.domains.alg), advm:bandMid(s.domains.advm), psd:bandMid(s.domains.psd), gt:bandMid(s.domains.gt) };
    return map[domain] || s.total;
  };

  const domainLabel = document.getElementById('group-domain').options[document.getElementById('group-domain').selectedIndex].text;

  let sorted = [...fs].sort((a,b) => getScore(a) - getScore(b));
  const groups = [];

  if (mode === 'similar') {
    for (let i = 0; i < sorted.length; i += size) {
      groups.push(sorted.slice(i, i + size));
    }
  } else {
    // Mixed: interleave top and bottom
    const mixed = [];
    let lo = 0, hi = sorted.length - 1;
    while (lo <= hi) {
      if (lo !== hi) { mixed.push(sorted[lo++]); mixed.push(sorted[hi--]); }
      else { mixed.push(sorted[lo++]); }
    }
    for (let i = 0; i < mixed.length; i += size) {
      groups.push(mixed.slice(i, i + size));
    }
  }

  const colors = ['var(--accent-blue)','var(--accent-green)','var(--accent-yellow)','var(--accent-purple)','#fb923c','#22d3ee','#f472b6','#a3e635'];
  const groupNames = ['Group A','Group B','Group C','Group D','Group E','Group F','Group G','Group H'];

  document.getElementById('group-results').innerHTML = `
    <div style="margin-bottom:14px;font-size:13px;color:var(--text-secondary)">
      ${groups.length} groups · Focus: <strong style="color:var(--text-primary)">${domainLabel}</strong> · Mode: <strong style="color:var(--text-primary)">${mode === 'similar' ? 'Similar levels' : 'Mixed levels'}</strong>
    </div>
    <div class="group-results">
      ${groups.map((g, i) => {
        const scores = g.map(s => getScore(s));
        const avgScore = Math.round(scores.reduce((a,b)=>a+b,0)/scores.length);
        const color = colors[i % colors.length];
        return `<div class="group-card">
          <div class="group-card-header" style="border-top: 3px solid ${color}">
            <div>
              <div class="group-name">${groupNames[i] || 'Group '+(i+1)}</div>
              <div class="group-focus">Avg: ${avgScore}</div>
            </div>
            <div class="group-count" style="color:${color}">${g.length}</div>
          </div>
          <div class="group-body">
            ${g.map(s => {
              const sc = getScore(s);
              const bm = BENCHMARKS[s.grade];
              const flags = [];
              if (!s.rwMet) flags.push('<span class="tag tag-critical" style="font-size:10px">RW</span>');
              if (!s.mathMet) flags.push('<span class="tag tag-watch" style="font-size:10px">Math</span>');
              return `<div class="group-student-row">
                <div>
                  <div class="gs-name">${s.name}</div>
                  <div style="font-size:11px;color:var(--text-secondary)">Gr. ${s.grade} · T${s.tier}</div>
                </div>
                <div style="display:flex;align-items:center;gap:6px">
                  ${flags.join('')}
                  <span class="gs-score" style="color:${scoreToColor(sc)}">${sc}</span>
                </div>
              </div>`;
            }).join('')}
          </div>
        </div>`;
      }).join('')}
    </div>
  `;
}

// ─── ATTENDANCE ───────────────────────────────────────────────────────────────
function renderAttStats() {
  const fs = filteredStudents();
  const chronic = fs.filter(s => s.chronic).length;
  const approaching = fs.filter(s => !s.chronic && s.absences >= 10).length;
  const onTrack = fs.filter(s => s.absences < 10).length;
  const avgAbs = (fs.reduce((a,s)=>a+s.absences,0)/fs.length).toFixed(1);

  document.getElementById('att-stats-row').innerHTML = `
    <div class="stat-card">
      <div class="stat-label">Avg Days Absent</div>
      <div class="stat-value">${avgAbs}</div>
      <div class="stat-sub">of 180 school days</div>
      <div class="stat-bar"><div class="stat-bar-fill" style="width:${Math.min(parseFloat(avgAbs)/40*100,100)}%;background:${parseFloat(avgAbs)>=18?'var(--accent-red)':parseFloat(avgAbs)>=10?'var(--accent-yellow)':'var(--accent-green)'}"></div></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Chronically Absent</div>
      <div class="stat-value" style="color:var(--accent-red)">${chronic}</div>
      <div class="stat-sub">${Math.round(chronic/fs.length*100)}% of cohort · 18+ days</div>
      <div class="stat-bar"><div class="stat-bar-fill" style="width:${Math.round(chronic/fs.length*100)}%;background:var(--accent-red)"></div></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Approaching Chronic</div>
      <div class="stat-value" style="color:var(--accent-yellow)">${approaching}</div>
      <div class="stat-sub">${Math.round(approaching/fs.length*100)}% of cohort · 10–17 days</div>
      <div class="stat-bar"><div class="stat-bar-fill" style="width:${Math.round(approaching/fs.length*100)}%;background:var(--accent-yellow)"></div></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">On Track</div>
      <div class="stat-value" style="color:var(--accent-green)">${onTrack}</div>
      <div class="stat-sub">${Math.round(onTrack/fs.length*100)}% of cohort · under 10 days</div>
      <div class="stat-bar"><div class="stat-bar-fill" style="width:${Math.round(onTrack/fs.length*100)}%;background:var(--accent-green)"></div></div>
    </div>
  `;
}

function renderAttendance() {
  renderAttStats();
  const fs = filteredStudents();
  const sortVal = document.getElementById('att-sort') ? document.getElementById('att-sort').value : 'absences';
  const sorted = [...fs].sort((a,b) => {
    if (sortVal === 'name') return a.name.localeCompare(b.name);
    if (sortVal === 'pct') return b.absPct - a.absPct;
    return b.absences - a.absences;
  });

  document.getElementById('att-tbody').innerHTML = sorted.map(s => {
    const attColor = s.chronic ? 'var(--accent-red)' : s.absences >= 10 ? 'var(--accent-yellow)' : 'var(--accent-green)';
    const statusLabel = s.chronic ? '<span class="chronic-badge">⚠ Chronic</span>' : s.absences >= 10 ? '<span class="tag tag-watch">Approaching</span>' : '<span class="tag tag-strong">On Track</span>';
    const barPct = Math.min(s.absences / 40 * 100, 100);
    const threshPct = 18/40*100; // chronic threshold at 18 days, bar max=40
    return `<div class="att-student-row" onclick="openProfile(${s.id})">
      <div>
        <div style="font-size:14px;font-weight:600">${s.name}</div>
        <div style="font-size:11px;color:var(--text-secondary)">Gr. ${s.grade} &nbsp;·&nbsp; T${s.tier} ${s.tier===1?'· <span style="color:var(--accent-red)">Below both benchmarks</span>':''}</div>
      </div>
      <div style="text-align:center;font-size:16px;font-weight:700;color:${attColor}">${s.absences}</div>
      <div style="text-align:center;font-size:14px;font-weight:600;color:${attColor}">${s.absPct}%</div>
      <div style="text-align:center">${statusLabel}</div>
      <div class="att-bar-wrap">
        <div class="att-bar-track">
          <div class="att-bar-fill" style="width:${barPct}%;background:${attColor}"></div>
          <div class="att-threshold" style="left:${threshPct}%" title="Chronic: 18 days"></div>
        </div>
      </div>
    </div>`;
  }).join('');
}

