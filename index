  { id: 18, name: 'Rashida Abboud',    grade: 11, rw: 600, math: 580, absences: 7,  domains: { ii:6,cs:5,eoi:6,sec:6, alg:6,advm:5,psd:5,gt:6 } },
  { id: 19, name: 'Sam Lockwood',      grade: 10, rw: 490, math: 480, absences: 12, domains: { ii:4,cs:4,eoi:5,sec:4, alg:5,advm:4,psd:4,gt:4 } },
