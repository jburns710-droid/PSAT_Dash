}

// ─── HEATMAP ─────────────────────────────────────────────────────────────────
function bandClass(b) {
  if (b <= 2) return 'band-' + b;
  if (b <= 4) return 'band-' + b;
  return 'band-' + b;
}

function renderHeatmap() {
  const fs = filteredStudents();
  const sorted = [...fs].sort((a,b) => b.total - a.total);
  const tbody = document.getElementById('heatmap-tbody');
  const bm_cols = ['ii','cs','eoi','sec','alg','advm','psd','gt'];

  tbody.innerHTML = sorted.map(s => {
    const bm = BENCHMARKS[s.grade];
    const rwStatus = s.rwMet ? '<span class="tag tag-strong">✓</span>' : s.rw >= bm.rw - 30 ? '<span class="tag tag-watch">Near</span>' : '<span class="tag tag-critical">✗</span>';
    const mStatus = s.mathMet ? '<span class="tag tag-strong">✓</span>' : s.math >= bm.math - 30 ? '<span class="tag tag-watch">Near</span>' : '<span class="tag tag-critical">✗</span>';
    const domCells = bm_cols.map(d => `<td class="domain-cell domain-col"><span class="band-pill band-${s.domains[d]}">${s.domains[d]}</span></td>`).join('');
    const tierColor = s.tier === 1 ? 'var(--accent-red)' : s.tier === 2 ? 'var(--accent-yellow)' : 'var(--accent-green)';
    return `<tr onclick="openProfile(${s.id})">
      <td><span class="student-name">${s.name}</span></td>
      <td><span style="font-size:13px;color:var(--text-secondary)">${s.grade}</span></td>
      <td class="score-cell" style="color:${scoreToColor(s.rw)}">${s.rw}</td>
      <td class="score-cell" style="color:${scoreToColor(s.math)}">${s.math}</td>
      <td class="score-cell" style="color:${scoreToColor(s.total)};font-size:15px">${s.total}</td>
      <td class="score-cell" style="color:var(--text-secondary)">${s.idx}</td>
      ${domCells}
      <td>${rwStatus}</td>
      <td>${mStatus}</td>
    </tr>`;
  }).join('');
}

// ─── TIERS ───────────────────────────────────────────────────────────────────
