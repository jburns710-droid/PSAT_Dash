function renderProfileSelect() {
  const sel = document.getElementById('profile-select');
  sel.innerHTML = [...STUDENTS].sort((a,b)=>a.name.localeCompare(b.name)).map(s =>
    `<option value="${s.id}">${s.name} (Gr. ${s.grade})</option>`
