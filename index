<script>
// ─── DATA ───────────────────────────────────────────────────────────────────

const DOMAINS_RW = ['ii','cs','eoi','sec'];
const DOMAINS_MATH = ['alg','advm','psd','gt'];
const DOMAIN_LABELS = {
  ii: 'Info & Ideas', cs: 'Craft & Structure',
  eoi: 'Expression of Ideas', sec: 'Standard English',
  alg: 'Algebra', advm: 'Advanced Math',
  psd: 'Problem Solving & Data', gt: 'Geometry & Trig'
};
const BENCHMARKS = {
  10: { rw: 430, math: 480 },
  11: { rw: 460, math: 510 }
};

// Band midpoints for domain score estimation
// Bands 1–7 mapped roughly to score range 160–760 in 6 steps
const BAND_RANGES = {
  1: [160, 280], 2: [280, 370], 3: [370, 440],
  4: [440, 520], 5: [520, 590], 6: [590, 660], 7: [660, 760]
};
function bandMid(b) { const r = BAND_RANGES[b]; return Math.round((r[0]+r[1])/2); }

function scoreToColor(score, section='rw') {
  const pct = (score - 160) / (760 - 160);
  if (pct < 0.25) return 'var(--accent-red)';
  if (pct < 0.45) return 'var(--accent-yellow)';
  return 'var(--accent-green)';
}

const STUDENTS = [
  { id: 1,  name: 'Aaliyah Torres',    grade: 11, rw: 620, math: 500, absences: 4,  domains: { ii:6,cs:5,eoi:5,sec:6, alg:5,advm:4,psd:5,gt:4 } },
  { id: 2,  name: 'Ben Kowalski',      grade: 11, rw: 480, math: 470, absences: 11, domains: { ii:4,cs:4,eoi:3,sec:4, alg:4,advm:3,psd:4,gt:3 } },
  { id: 3,  name: 'Carmen Rivera',     grade: 10, rw: 390, math: 420, absences: 22, domains: { ii:3,cs:3,eoi:2,sec:3, alg:3,advm:3,psd:2,gt:3 } },
  { id: 4,  name: 'Dante Williams',    grade: 11, rw: 540, math: 560, absences: 2,  domains: { ii:5,cs:5,eoi:5,sec:5, alg:6,advm:5,psd:5,gt:5 } },
  { id: 5,  name: 'Elise Nguyen',      grade: 10, rw: 450, math: 390, absences: 19, domains: { ii:4,cs:3,eoi:4,sec:4, alg:3,advm:2,psd:3,gt:2 } },
  { id: 6,  name: 'Felix Okonkwo',     grade: 11, rw: 360, math: 340, absences: 31, domains: { ii:2,cs:2,eoi:3,sec:2, alg:2,advm:2,psd:2,gt:1 } },
  { id: 7,  name: 'Grace Kim',         grade: 10, rw: 690, math: 680, absences: 1,  domains: { ii:7,cs:7,eoi:6,sec:7, alg:7,advm:6,psd:7,gt:6 } },
  { id: 8,  name: 'Harrison Blake',    grade: 11, rw: 410, math: 430, absences: 14, domains: { ii:3,cs:3,eoi:3,sec:4, alg:3,advm:3,psd:4,gt:3 } },
  { id: 9,  name: 'Imani Johnson',     grade: 10, rw: 520, math: 510, absences: 6,  domains: { ii:5,cs:4,eoi:5,sec:5, alg:5,advm:5,psd:4,gt:5 } },
  { id: 10, name: 'Jared Patel',       grade: 11, rw: 580, math: 530, absences: 8,  domains: { ii:5,cs:6,eoi:5,sec:5, alg:5,advm:5,psd:5,gt:4 } },
  { id: 11, name: 'Kyla Marchetti',    grade: 10, rw: 320, math: 310, absences: 27, domains: { ii:2,cs:1,eoi:2,sec:2, alg:1,advm:1,psd:2,gt:1 } },
