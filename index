  { id: 14, name: 'Noah Steinberg',    grade: 11, rw: 500, math: 490, absences: 16, domains: { ii:4,cs:5,eoi:4,sec:5, alg:4,advm:4,psd:5,gt:4 } },
  { id: 15, name: 'Olivia Chandra',    grade: 10, rw: 560, math: 540, absences: 5,  domains: { ii:5,cs:5,eoi:5,sec:6, alg:5,advm:5,psd:5,gt:5 } },
  { id: 16, name: 'Priya Sundaram',    grade: 11, rw: 430, math: 400, absences: 20, domains: { ii:3,cs:4,eoi:3,sec:3, alg:3,advm:2,psd:3,gt:3 } },
