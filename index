function openProfile(id) {
  showTab('profile', document.querySelectorAll('.nav-tab')[2]);
  document.getElementById('profile-select').value = id;
  renderProfile(id);
}

function renderProfile(id) {
  const s = STUDENTS.find(x => x.id == id);
  if (!s) return;
  const bm = BENCHMARKS[s.grade];

  const allDomains = [
    ...DOMAINS_RW.map(d => ({key:d, label:DOMAIN_LABELS[d], section:'Reading & Writing'})),
    ...DOMAINS_MATH.map(d => ({key:d, label:DOMAIN_LABELS[d], section:'Math'}))
  ];

  const domColors = (band) => {
    if (band <= 2) return 'var(--accent-red)';
    if (band <= 4) return 'var(--accent-yellow)';
    return 'var(--accent-green)';
  };

  const tierLabel = s.tier === 1
    ? '<span class="tag tag-critical">Intensive Support</span>'
    : s.tier === 2
    ? '<span class="tag tag-watch">Strategic Support</span>'
    : '<span class="tag tag-strong">On Track</span>';

  // Always show both sections — criterion first, then relative fallback
  const bandsSorted = [...allDomains].sort((a,b) => s.domains[b.key] - s.domains[a.key]);
  const criterionStrong = allDomains.filter(d => s.domains[d.key] >= 6);
  const criterionWeak   = allDomains.filter(d => s.domains[d.key] <= 3);

  // Relative: top 3 / bottom 3 by band value (used when criterion list is empty)
  const relStrong = bandsSorted.slice(0, 3);
  const relWeak   = bandsSorted.slice(-3).reverse();

  const strengthList = criterionStrong.length ? criterionStrong : relStrong;
  const focusList    = criterionWeak.length   ? criterionWeak   : relWeak;
  const strengthNote = criterionStrong.length ? '' : '<span style="font-size:11px;color:var(--text-muted);margin-left:6px">(relative)</span>';
  const focusNote    = criterionWeak.length   ? '' : '<span style="font-size:11px;color:var(--text-muted);margin-left:6px">(relative)</span>';

  // Attendance
  const attColor = s.chronic ? 'var(--accent-red)' : s.absences >= 10 ? 'var(--accent-yellow)' : 'var(--accent-green)';
  const attStatus = s.chronic ? 'Chronically Absent' : s.absences >= 10 ? 'Approaching Chronic' : 'On Track';
  const attPct = Math.round(s.absences / 180 * 100);

  document.getElementById('profile-content').innerHTML = `
    <div class="profile-grid">
