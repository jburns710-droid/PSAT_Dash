<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PSAT/NMSQT Cohort Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg-main: #0f172a;
  --bg-card: #1e293b;
  --bg-card-hover: #243347;
  --bg-input: #0b1220;
  --bg-surface: #162032;

  --text-primary: #e2e8f0;
  --text-secondary: #94a3b8;
  --text-muted: #64748b;

  --border-subtle: #334155;
  --border-medium: #475569;

  --accent-blue: #3b82f6;
  --accent-blue-dim: rgba(59,130,246,0.15);
  --accent-green: #22c55e;
  --accent-green-dim: rgba(34,197,94,0.12);
  --accent-yellow: #f59e0b;
  --accent-yellow-dim: rgba(245,158,11,0.12);
  --accent-red: #ef4444;
  --accent-red-dim: rgba(239,68,68,0.12);
  --accent-purple: #a78bfa;

  --space-1: 6px;
  --space-2: 10px;
  --space-3: 14px;
  --space-4: 18px;
  --space-5: 24px;
  --space-6: 32px;

  --radius: 10px;
  --radius-sm: 6px;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: "Source Sans 3", system-ui, -apple-system, sans-serif;
  font-size: 16px;
  line-height: 1.5;
  background: var(--bg-main);
  color: var(--text-primary);
  min-height: 100vh;
}

/* HEADER */
.app-header {
  background: var(--bg-card);
  border-bottom: 1px solid var(--border-subtle);
  padding: 0 var(--space-6);
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 60px;
  position: sticky;
  top: 0;
  z-index: 100;
}
.app-title {
  display: flex;
  align-items: center;
  gap: 12px;
}
.app-title .logo-badge {
  background: var(--accent-blue);
  color: white;
  font-size: 11px;
  font-weight: 700;
  padding: 3px 8px;
  border-radius: 4px;
  letter-spacing: 0.05em;
}
.app-title h1 {
  font-size: 18px;
  font-weight: 600;
  color: var(--text-primary);
}
.header-meta {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  font-size: 13px;
  color: var(--text-secondary);
}
.header-meta .grade-filter {
  display: flex;
  gap: var(--space-2);
}
.grade-btn {
  background: var(--bg-input);
  border: 1px solid var(--border-subtle);
  color: var(--text-secondary);
  font-size: 12px;
  font-weight: 600;
  padding: 4px 10px;
  border-radius: 5px;
  cursor: pointer;
  transition: all 0.15s;
  font-family: inherit;
}
.grade-btn.active, .grade-btn:hover {
  background: var(--accent-blue-dim);
  border-color: var(--accent-blue);
  color: var(--accent-blue);
}

/* NAV TABS */
.nav-tabs {
  display: flex;
  gap: 2px;
  background: var(--bg-card);
  border-bottom: 1px solid var(--border-subtle);
  padding: 0 var(--space-6);
}
.nav-tab {
  padding: 12px 18px;
  font-size: 14px;
  font-weight: 500;
  color: var(--text-secondary);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  transition: all 0.15s;
  white-space: nowrap;
  background: none;
  border-top: none;
  border-left: none;
  border-right: none;
  font-family: inherit;
}
.nav-tab:hover { color: var(--text-primary); }
.nav-tab.active {
  color: var(--accent-blue);
  border-bottom-color: var(--accent-blue);
  font-weight: 600;
}

/* MAIN LAYOUT */
.main {
  padding: var(--space-5) var(--space-6);
  max-width: 1400px;
  margin: 0 auto;
}

/* CARDS */
.card {
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: var(--space-4);
  border: 1px solid var(--border-subtle);
}
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14px;
}
.card-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary);
}
.card-subtitle {
  font-size: 13px;
  color: var(--text-secondary);
  margin-top: 2px;
}

/* TAGS */
.tag {
  font-size: 11px;
  padding: 3px 8px;
  border-radius: 5px;
  font-weight: 600;
  letter-spacing: 0.03em;
}
.tag-critical { background: var(--accent-red-dim); color: var(--accent-red); }
.tag-watch    { background: var(--accent-yellow-dim); color: var(--accent-yellow); }
.tag-strong   { background: var(--accent-green-dim); color: var(--accent-green); }
.tag-blue     { background: var(--accent-blue-dim); color: var(--accent-blue); }

/* TABS CONTENT */
.tab-panel { display: none; }
.tab-panel.active { display: block; }

/* STATS ROW */
.stats-row {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: var(--space-4);
  margin-bottom: var(--space-5);
}
.stat-card {
  background: var(--bg-card);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius);
  padding: var(--space-4);
}
.stat-label {
  font-size: 12px;
  color: var(--text-secondary);
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 6px;
}
.stat-value {
  font-size: 28px;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1;
}
.stat-sub {
  font-size: 12px;
  color: var(--text-secondary);
  margin-top: 4px;
}
.stat-bar {
  height: 3px;
  background: var(--border-subtle);
  border-radius: 2px;
  margin-top: 10px;
}
.stat-bar-fill {
  height: 100%;
  border-radius: 2px;
  transition: width 0.6s ease;
}

/* HEATMAP TABLE */
.heatmap-container {
  overflow-x: auto;
}
.heatmap-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
}
.heatmap-table thead th {
  padding: 8px 10px;
  text-align: left;
  font-size: 11px;
  font-weight: 600;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  border-bottom: 1px solid var(--border-subtle);
  white-space: nowrap;
  background: var(--bg-card);
  position: sticky;
  top: 0;
}
.heatmap-table tbody tr {
  border-bottom: 1px solid rgba(51,65,85,0.5);
  cursor: pointer;
  transition: background 0.1s;
}
.heatmap-table tbody tr:hover { background: var(--bg-card-hover); }
.heatmap-table td {
  padding: 9px 10px;
  white-space: nowrap;
}
.student-name {
  font-weight: 600;
  font-size: 14px;
  color: var(--text-primary);
}
.score-cell {
  font-size: 14px;
  font-weight: 600;
  text-align: center;
}
.domain-cell {
  width: 60px;
  text-align: center;
}
.band-pill {
  display: inline-block;
  width: 36px;
  height: 22px;
  border-radius: 4px;
  font-size: 11px;
  font-weight: 700;
  line-height: 22px;
  text-align: center;
}

/* band colors */
.band-1 { background: rgba(239,68,68,0.25); color: #fca5a5; }
.band-2 { background: rgba(239,68,68,0.15); color: #f87171; }
.band-3 { background: rgba(245,158,11,0.15); color: #fcd34d; }
.band-4 { background: rgba(245,158,11,0.1); color: #f59e0b; }
.band-5 { background: rgba(34,197,94,0.1); color: #86efac; }
.band-6 { background: rgba(34,197,94,0.15); color: #4ade80; }
.band-7 { background: rgba(59,130,246,0.15); color: #93c5fd; }

/* TIER SECTION */
.tier-section { margin-bottom: var(--space-5); }
.tier-header {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px var(--space-4);
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius);
  cursor: pointer;
  transition: background 0.15s;
  margin-bottom: 2px;
}
.tier-header:hover { background: var(--bg-card-hover); }
.tier-header.open { border-bottom-left-radius: 0; border-bottom-right-radius: 0; border-bottom-color: transparent; }
.tier-icon {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 700;
  flex-shrink: 0;
}
.tier-icon.t1 { background: var(--accent-red-dim); color: var(--accent-red); }
.tier-icon.t2 { background: var(--accent-yellow-dim); color: var(--accent-yellow); }
.tier-icon.t3 { background: var(--accent-green-dim); color: var(--accent-green); }
.tier-meta { flex: 1; }
.tier-title { font-size: 15px; font-weight: 600; }
.tier-desc { font-size: 13px; color: var(--text-secondary); margin-top: 1px; }
.tier-count {
  font-size: 24px;
  font-weight: 700;
  padding-right: 12px;
}
.tier-toggle {
  color: var(--text-muted);
  font-size: 16px;
  transition: transform 0.2s;
}
.tier-toggle.open { transform: rotate(180deg); }

.tier-body {
  display: none;
  background: var(--bg-card);
  border: 1px solid var(--border-subtle);
  border-top: none;
  border-bottom-left-radius: var(--radius);
  border-bottom-right-radius: var(--radius);
  padding: var(--space-4);
}
.tier-body.open { display: block; }

.student-cards {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 12px;
}
.student-card {
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 8px;
  padding: 14px;
  cursor: pointer;
  transition: all 0.15s;
}
.student-card:hover {
  border-color: var(--accent-blue);
  background: var(--bg-card-hover);
}
.sc-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 10px;
}
.sc-name { font-size: 14px; font-weight: 600; }
.sc-grade { font-size: 12px; color: var(--text-secondary); margin-top: 1px; }
.sc-total { font-size: 22px; font-weight: 700; }
.sc-bars { margin-top: 10px; }
.sc-bar-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 6px;
}
.sc-bar-label {
  font-size: 11px;
  color: var(--text-secondary);
  width: 30px;
  flex-shrink: 0;
}
.sc-bar-track {
  flex: 1;
  height: 5px;
  background: var(--border-subtle);
  border-radius: 3px;
}
.sc-bar-fill {
  height: 100%;
  border-radius: 3px;
  transition: width 0.5s ease;
}
.sc-score-val {
  font-size: 12px;
  font-weight: 600;
  width: 30px;
  text-align: right;
}
.bench-line {
  position: relative;
}
.bench-marker {
  position: absolute;
  top: -4px;
  width: 2px;
  height: 13px;
  background: var(--text-muted);
  border-radius: 1px;
}

/* INDIVIDUAL PROFILE */
.profile-selector {
  display: flex;
  gap: var(--space-3);
  align-items: center;
  margin-bottom: var(--space-5);
}
.profile-selector label {
  font-size: 13px;
  color: var(--text-secondary);
  font-weight: 500;
}
.profile-selector select {
  background: var(--bg-input);
  border: 1px solid var(--border-subtle);
  color: var(--text-primary);
  font-family: inherit;
  font-size: 14px;
  padding: 8px 14px;
  border-radius: 6px;
  cursor: pointer;
  outline: none;
  min-width: 220px;
}
.profile-selector select:focus { border-color: var(--accent-blue); }

.profile-grid {
  display: grid;
  grid-template-columns: 320px 1fr;
  gap: var(--space-5);
}
.profile-score-panel {}
.score-big {
  text-align: center;
  padding: var(--space-5);
  background: var(--bg-surface);
  border-radius: var(--radius);
  border: 1px solid var(--border-subtle);
  margin-bottom: 14px;
}
.score-big .total { font-size: 52px; font-weight: 700; line-height: 1; }
.score-big .total-label { font-size: 12px; color: var(--text-secondary); margin-top: 4px; }
.score-big .sections {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-top: 18px;
}
.score-section {
  background: var(--bg-card);
  border-radius: 8px;
  padding: 12px;
  text-align: center;
  border: 1px solid var(--border-subtle);
}
.score-section .sec-val { font-size: 26px; font-weight: 700; }
.score-section .sec-label { font-size: 11px; color: var(--text-secondary); margin-top: 2px; }
.score-section .sec-bench { font-size: 11px; margin-top: 5px; }

.benchmark-status {
  padding: 14px;
  background: var(--bg-surface);
  border-radius: var(--radius);
  border: 1px solid var(--border-subtle);
  margin-bottom: 14px;
}
.bm-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6px 0;
  border-bottom: 1px solid rgba(51,65,85,0.5);
}
.bm-row:last-child { border-bottom: none; }
.bm-area { font-size: 13px; }
.bm-status { font-size: 12px; font-weight: 600; }
.met { color: var(--accent-green); }
.not-met { color: var(--accent-red); }
.approaching { color: var(--accent-yellow); }

/* DOMAIN BARS */
.domains-panel {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}
.domain-card {
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 8px;
  padding: 14px;
}
.domain-card .dom-label { font-size: 13px; font-weight: 600; margin-bottom: 4px; }
.domain-card .dom-section { font-size: 11px; color: var(--text-secondary); margin-bottom: 10px; }
.dom-bar-track {
  height: 8px;
  background: var(--border-subtle);
  border-radius: 4px;
  position: relative;
  margin-bottom: 6px;
}
.dom-bar-fill {
  height: 100%;
  border-radius: 4px;
}
.dom-range {
  font-size: 12px;
  font-weight: 600;
  color: var(--text-primary);
}
.dom-pct { font-size: 11px; color: var(--text-secondary); }

/* GROWTH CHART */
.growth-chart-wrap {
  margin-top: 14px;
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius);
  padding: var(--space-4);
}
.growth-chart {
  width: 100%;
  height: 160px;
}

/* GROUPING TOOL */
.grouping-controls {
  display: flex;
  gap: var(--space-4);
  margin-bottom: var(--space-5);
  flex-wrap: wrap;
  align-items: flex-end;
}
.control-group { display: flex; flex-direction: column; gap: 5px; }
.control-group label { font-size: 12px; color: var(--text-secondary); font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; }
.control-group select, .control-group input {
  background: var(--bg-input);
  border: 1px solid var(--border-subtle);
  color: var(--text-primary);
  font-family: inherit;
  font-size: 14px;
  padding: 8px 14px;
  border-radius: 6px;
  outline: none;
  min-width: 180px;
}
.control-group select:focus, .control-group input:focus { border-color: var(--accent-blue); }
.run-btn {
  background: var(--accent-blue);
  color: white;
  border: none;
  font-family: inherit;
  font-size: 14px;
  font-weight: 600;
  padding: 9px 20px;
  border-radius: 6px;
  cursor: pointer;
  transition: background 0.15s;
  align-self: flex-end;
}
.run-btn:hover { background: #2563eb; }

.group-results {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: var(--space-4);
}
.group-card {
  background: var(--bg-card);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius);
  overflow: hidden;
}
.group-card-header {
  padding: 12px var(--space-4);
  border-bottom: 1px solid var(--border-subtle);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.group-name { font-size: 14px; font-weight: 600; }
.group-focus { font-size: 12px; color: var(--text-secondary); }
.group-count { font-size: 20px; font-weight: 700; }
.group-body { padding: var(--space-4); }
.group-student-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 7px 0;
  border-bottom: 1px solid rgba(51,65,85,0.4);
  font-size: 13px;
}
.group-student-row:last-child { border-bottom: none; }
.gs-name { font-weight: 500; }
.gs-score { font-weight: 600; color: var(--text-secondary); }
.gs-flag { font-size: 11px; }

/* MINI BAR HORIZONTAL */
.mini-bar {
  height: 5px;
  border-radius: 3px;
  background: var(--border-subtle);
  margin-top: 8px;
}
.mini-bar-fill {
  height: 100%;
  border-radius: 3px;
}

/* SECTION DIVIDERS */
.section-label {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--text-muted);
  margin-bottom: 10px;
  padding-bottom: 6px;
  border-bottom: 1px solid var(--border-subtle);
}

/* ATTENDANCE */
.att-bar-track {
  height: 8px;
  background: var(--border-subtle);
  border-radius: 4px;
  position: relative;
}
.att-bar-fill { height: 100%; border-radius: 4px; }
.att-threshold {
  position: absolute;
  top: -4px;
  width: 2px;
  height: 16px;
  background: var(--accent-red);
  border-radius: 1px;
  opacity: 0.7;
}
.chronic-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 11px;
  font-weight: 700;
  padding: 3px 9px;
  border-radius: 5px;
  background: rgba(239,68,68,0.15);
  color: var(--accent-red);
  letter-spacing: 0.02em;
}
.att-student-row {
  display: grid;
  grid-template-columns: 1fr 80px 80px 100px 120px;
  align-items: center;
  gap: 12px;
  padding: 10px 12px;
  border-bottom: 1px solid rgba(51,65,85,0.5);
  font-size: 13px;
  cursor: pointer;
  transition: background 0.1s;
  border-radius: 4px;
}
.att-student-row:hover { background: var(--bg-card-hover); }
.att-student-row:last-child { border-bottom: none; }
.att-col-header {
  display: grid;
  grid-template-columns: 1fr 80px 80px 100px 120px;
  gap: 12px;
  padding: 6px 12px;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--text-muted);
  border-bottom: 1px solid var(--border-subtle);
  margin-bottom: 4px;
}
.att-bar-wrap { width: 100%; }

/* Collapsible domain columns */
.domain-col { transition: opacity 0.2s; }
.domains-hidden .domain-col { display: none; }

.toggle-domains-btn {
  background: var(--bg-input);
  border: 1px solid var(--border-subtle);
  color: var(--text-secondary);
  font-family: inherit;
  font-size: 12px;
  font-weight: 600;
  padding: 4px 12px;
  border-radius: 5px;
  cursor: pointer;
  transition: all 0.15s;
  white-space: nowrap;
}
.toggle-domains-btn:hover, .toggle-domains-btn.active {
  background: var(--accent-blue-dim);
  border-color: var(--accent-blue);
  color: var(--accent-blue);
}

/* Scrollbar */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: var(--bg-main); }
::-webkit-scrollbar-thumb { background: var(--border-medium); border-radius: 3px; }

/* Responsive */
@media (max-width: 1100px) {
  .stats-row { grid-template-columns: repeat(3, 1fr); }
  .profile-grid { grid-template-columns: 1fr; }
}
@media (max-width: 768px) {
  .stats-row { grid-template-columns: repeat(2, 1fr); }
  .main { padding: var(--space-4); }
  .nav-tabs { overflow-x: auto; padding: 0 var(--space-4); }
}

/* Animations */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(4px); }
  to { opacity: 1; transform: translateY(0); }
}
.tab-panel.active { animation: fadeIn 0.2s ease; }

.highlight-bench { color: var(--accent-yellow); font-weight: 700; }
</style>
</head>
<body>

<header class="app-header">
  <div class="app-title">
    <span class="logo-badge">PSAT</span>
    <h1>Cohort Dashboard &mdash; Fall 2025</h1>
  </div>
  <div class="header-meta">
    <div class="grade-filter">
      <button class="grade-btn active" onclick="setGradeFilter('all', this)">All Grades</button>
      <button class="grade-btn" onclick="setGradeFilter('10', this)">Grade 10</button>
      <button class="grade-btn" onclick="setGradeFilter('11', this)">Grade 11</button>
    </div>
    <span id="header-count" style="font-size:13px; color: var(--text-secondary);">20 students</span>
  </div>
</header>

<nav class="nav-tabs">
  <button class="nav-tab active" onclick="showTab('overview', this)">Cohort Overview</button>
  <button class="nav-tab" onclick="showTab('tiers', this)">Tier Groups</button>
  <button class="nav-tab" onclick="showTab('profile', this)">Individual Profile</button>
  <button class="nav-tab" onclick="showTab('attendance', this)">Attendance</button>
