];

STUDENTS.forEach(s => {
  s.total = s.rw + s.math;
  s.idx = Math.round((2 * s.rw + s.math) / 10);
  const bm = BENCHMARKS[s.grade];
  s.rwMet = s.rw >= bm.rw;
  s.mathMet = s.math >= bm.math;
  const metCount = (s.rwMet ? 1 : 0) + (s.mathMet ? 1 : 0);
  if (metCount === 2) s.tier = 3;
  else if (metCount === 1) s.tier = 2;
  else s.tier = 1;
  // Attendance
  s.absPct = Math.round(s.absences / 180 * 100);
  s.chronic = s.absences >= 18; // 10% of 180
});

let gradeFilter = 'all';

function filteredStudents() {
  if (gradeFilter === 'all') return STUDENTS;
  return STUDENTS.filter(s => String(s.grade) === gradeFilter);
}

// ─── GRADE FILTER ────────────────────────────────────────────────────────────
function setGradeFilter(g, btn) {
  gradeFilter = g;
  document.querySelectorAll('.grade-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const fs = filteredStudents();
  document.getElementById('header-count').textContent = `${fs.length} students`;
  renderAll();
}

// ─── TABS ────────────────────────────────────────────────────────────────────
function showTab(name, btn) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  btn.classList.add('active');
  if (name === 'attendance') renderAttendance();
}

// ─── STATS ROW ───────────────────────────────────────────────────────────────
function renderStats() {
  const fs = filteredStudents();
  const avgTotal = Math.round(fs.reduce((a,s)=>a+s.total,0)/fs.length);
  const avgRW = Math.round(fs.reduce((a,s)=>a+s.rw,0)/fs.length);
  const avgMath = Math.round(fs.reduce((a,s)=>a+s.math,0)/fs.length);
  const t1 = fs.filter(s=>s.tier===1).length;
  const t2 = fs.filter(s=>s.tier===2).length;
  const t3 = fs.filter(s=>s.tier===3).length;
  const bothMet = fs.filter(s=>s.rwMet&&s.mathMet).length;
  const pct = n => Math.round(n/fs.length*100);

  const stats = [
    { label: 'Avg Total', val: avgTotal, sub: `Range 320–1520`, bar: (avgTotal-320)/1200, color: scoreToColor(avgTotal) },
    { label: 'Avg RW', val: avgRW, sub: `Range 160–760`, bar: (avgRW-160)/600, color: scoreToColor(avgRW,'rw') },
    { label: 'Avg Math', val: avgMath, sub: `Range 160–760`, bar: (avgMath-160)/600, color: scoreToColor(avgMath,'math') },
    { label: 'Both Benchmarks Met', val: `${bothMet}/${fs.length}`, sub: `${pct(bothMet)}% college ready`, bar: bothMet/fs.length, color: 'var(--accent-green)' },
    { label: 'Needs Support (T1)', val: `${t1}/${fs.length}`, sub: `${pct(t1)}% below both benchmarks`, bar: t1/fs.length, color: 'var(--accent-red)' },
  ];

  document.getElementById('stats-row').innerHTML = stats.map(s => `
    <div class="stat-card">
      <div class="stat-label">${s.label}</div>
      <div class="stat-value">${s.val}</div>
      <div class="stat-sub">${s.sub}</div>
      <div class="stat-bar"><div class="stat-bar-fill" style="width:${Math.round(s.bar*100)}%;background:${s.color}"></div></div>
    </div>
  `).join('');
}

// ─── HEATMAP DOMAIN TOGGLE ────────────────────────────────────────────────────
let domainsVisible = false;
function toggleDomainCols() {
  domainsVisible = !domainsVisible;
  const table = document.getElementById('heatmap-table');
  const btn = document.getElementById('domain-toggle-btn');
  table.classList.toggle('domains-hidden', !domainsVisible);
  btn.classList.toggle('active', domainsVisible);
